    "cypress": "^15.11.0",
    "eslint": "^10.0.3",
    "eslint-plugin-jest": "^29.15.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.3.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
